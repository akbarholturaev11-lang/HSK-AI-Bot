  "grammar": [
    {
      "no": 1,
      "title": {
        "uz": "To'rt ton",
        "ru": "Четыре тона",
        "tj": "Чор садо"
      },
      "title_zh": "四声",
      "rule": {
        "uz": "Xitoy tilida har bir bo'g'in 4 xil tonda aytiladi:\n1-ton (—): baland va tekis — mā (ona)\n2-ton (ˊ): ko'tariluvchi — má (kanop o'simligi)\n3-ton (ˇ): tushib ko'tariluvchi — mǎ (ot)\n4-ton (ˋ): tushuvchi — mà (so'kishmoq)\n\nTon ma'noni o'zgartiradi!",
        "ru": "В китайском языке каждый слог произносится в одном из 4 тонов:\nТон 1 (—): ровный и высокий — mā (мама)\nТон 2 (ˊ): восходящий — má (конопля)\nТон 3 (ˇ): нисходяще-восходящий — mǎ (лошадь)\nТон 4 (ˋ): нисходящий — mà (ругать)\n\nТон меняет смысл слова!",
        "tj": "Дар забони чинӣ ҳар як ҳиҷо бо яке аз 4 садо гуфта мешавад:\nСадои 1 (—): баланд ва ҳамвор — mā (модар)\nСадои 2 (ˊ): боравандаи — má (канабис)\nСадои 3 (ˇ): поинравандаю боравандаи — mǎ (асп)\nСадои 4 (ˋ): поинравандаи — mà (дашном додан)\n\nСадо маъноро тағйир медиҳад!"
      },
      "examples": [
        {
          "zh": "妈",
          "pinyin": "mā",
          "translation": {
            "uz": "ona (1-ton)",
            "ru": "мама (1-й тон)",
            "tj": "модар (садои 1)"
          }
        },
        {
          "zh": "马",
          "pinyin": "mǎ",
          "translation": {
            "uz": "ot (3-ton)",
            "ru": "лошадь (3-й тон)",
            "tj": "асп (садои 3)"
          }
        },
        {
          "zh": "骂",
          "pinyin": "mà",
          "translation": {
            "uz": "so'kmoq (4-ton)",
            "ru": "ругать (4-й тон)",
            "tj": "дашном додан (садои 4)"
          }
        }
      ]
    },
    {
      "no": 2,
      "title": {
        "uz": "Ton o'zgarishi (3+3)",
        "ru": "Изменение тона (3+3)",
        "tj": "Тағйири садо (3+3)"
      },
      "title_zh": "变调 (3+3)",
      "rule": {
        "uz": "Ketma-ket ikkita 3-ton kelganda, birinchisi 2-tonga o'zgaradi.\n3+3 → 2+3\nMisol: 你(nǐ) + 好(hǎo) → nī hǎo (lekin yoziladi: nǐ hǎo)",
        "ru": "Когда два слога 3-го тона идут подряд, первый меняется на 2-й тон.\n3+3 → 2+3\nПример: 你(nǐ) + 好(hǎo) → nī hǎo (но пишется: nǐ hǎo)",
        "tj": "Вақте ки ду ҳиҷои садои 3 паи ҳам меоянд, аввалӣ ба садои 2 табдил меёбад.\n3+3 → 2+3\nМисол: 你(nǐ) + 好(hǎo) → nī hǎo (аммо навишта мешавад: nǐ hǎo)"
      },
      "examples": [
        {
          "zh": "你好",
          "pinyin": "nī hǎo → nǐ hǎo",
          "translation": {
