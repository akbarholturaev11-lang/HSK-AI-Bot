      "questions": [
        { "no": 1, "type": "audio_truefalse", "audio_text": "随着科技的发展，人们的生活变得更加方便了。", "prompt_zh": "科技发展让生活更方便。",
          "stem": { "uz": "Eshiting: yozilgan gap to'g'rimi?", "ru": "Послушайте: верно ли написанное?", "tj": "Гӯш кунед: ҷумла дуруст аст?" },
          "answer": true },
        { "no": 2, "type": "audio_choice", "audio_text": "这次会议主要讨论了公司明年的发展计划。",
          "stem": { "uz": "Yig'ilishda nima muhokama qilindi?", "ru": "Что обсуждалось на собрании?", "tj": "Дар маҷлис чӣ муҳокима шуд?" },
          "options": [
            { "zh": "明年的发展计划", "py": "míngnián de fāzhǎn jìhuà", "label": { "uz": "Kelasi yil rejasi", "ru": "План развития на след. год", "tj": "Нақшаи соли оянда" }, "ok": 1 },
            { "zh": "员工的工资", "py": "yuángōng de gōngzī", "label": { "uz": "Xodimlar maoshi", "ru": "Зарплата сотрудников", "tj": "Маоши кормандон" } },
            { "zh": "新办公室", "py": "xīn bàngōngshì", "label": { "uz": "Yangi ofis", "ru": "Новый офис", "tj": "Дафтари нав" } }
          ] },
        { "no": 3, "type": "audio_choice", "audio_text": "他做事很认真，从来不马虎。",
          "stem": { "uz": "U qanday odam?", "ru": "Какой он человек?", "tj": "Ӯ чӣ гуна одам аст?" },
          "options": [
            { "zh": "很认真", "py": "hěn rènzhēn", "label": { "uz": "Mas'uliyatli/jiddiy", "ru": "Ответственный", "tj": "Бомасъулият" }, "ok": 1 },
            { "zh": "很懒", "py": "hěn lǎn", "label": { "uz": "Dangasa", "ru": "Ленивый", "tj": "Танбал" } },
            { "zh": "很粗心", "py": "hěn cūxīn", "label": { "uz": "E'tiborsiz", "ru": "Невнимательный", "tj": "Бедиққат" } }
          ] },
        { "no": 4, "type": "audio_truefalse", "audio_text": "尽管遇到了很多困难，他还是坚持把项目完成了。", "prompt_zh": "他放弃了这个项目。",
          "stem": { "uz": "Eshiting va belgilang.", "ru": "Послушайте и определите.", "tj": "Гӯш кунед ва муайян кунед." },
          "answer": false },
        { "no": 5, "type": "audio_choice", "audio_text": "我建议你提前预订机票，这样会便宜一些。",
          "stem": { "uz": "Qanday maslahat berildi?", "ru": "Какой дан совет?", "tj": "Чӣ маслиҳат дода шуд?" },
          "options": [
            { "zh": "提前预订机票", "py": "tíqián yùdìng jīpiào", "label": { "uz": "Aviachiptani oldindan band qilish", "ru": "Заранее забронировать билет", "tj": "Чиптаро пешакӣ фармоиш додан" }, "ok": 1 },
            { "zh": "坐火车去", "py": "zuò huǒchē qù", "label": { "uz": "Poyezdda borish", "ru": "Ехать на поезде", "tj": "Бо қатора рафтан" } },
            { "zh": "取消旅行", "py": "qǔxiāo lǚxíng", "label": { "uz": "Sayohatni bekor qilish", "ru": "Отменить поездку", "tj": "Сафарро бекор кардан" } }
          ] }
      ]
    },
