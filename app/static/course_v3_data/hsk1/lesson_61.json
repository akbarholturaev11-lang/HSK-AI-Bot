  "dialogues": [
    {
      "scene": {
        "uz": "Dasturxon yonida — qachon va qayerda tanishdingiz",
        "ru": "За столом — когда и где познакомились",
        "tj": "Дар сари дастурхон — кай ва дар куҷо шинос шудед"
      },
      "dialogue": [
        {
          "speaker": "A",
          "zh": "你和李小姐是什么时候认识的？",
          "pinyin": "Nǐ hé Lǐ xiǎojiě shì shénme shíhou rènshi de?",
          "text": {
            "uz": "Siz Xonim Li bilan qachon tanishdingiz?",
            "ru": "Когда вы познакомились с мисс Ли?",
            "tj": "Шумо бо хонум Ли кай шинос шудед?"
          }
        },
        {
          "speaker": "B",
          "zh": "我们是2011年9月认识的。",
          "pinyin": "Wǒmen shì èr líng yī yī nián jiǔ yuè rènshi de.",
          "text": {
            "uz": "Biz 2011-yilning sentabrida tanishdik.",
            "ru": "Мы познакомились в сентябре 2011 года.",
            "tj": "Мо дар моҳи сентябри соли 2011 шинос шудем."
          }
        },
        {
          "speaker": "A",
          "zh": "你们在哪儿认识的？",
          "pinyin": "Nǐmen zài nǎr rènshi de?",
