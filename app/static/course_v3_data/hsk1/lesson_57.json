            "tj": "Баъд аз 40 дақиқа бармегардад."
          }
        }
      ]
    },
    {
      "scene": {
        "uz": "Do'kon oldida — kiyimlar",
        "ru": "У магазина — одежда",
        "tj": "Дар назди дӯкон — либосҳо"
      },
      "dialogue": [
        {
          "speaker": "A",
          "zh": "王方的衣服太漂亮了！",
