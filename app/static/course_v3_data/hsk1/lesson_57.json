    {
      "scene": {
        "uz": "Yotoqxonada — kecha nima qilding",
        "ru": "В комнате — что делал вчера",
        "tj": "Дар хоб — дирӯз чӣ кардӣ"
      },
      "dialogue": [
        {
          "speaker": "A",
          "zh": "昨天上午你去哪儿了？",
          "pinyin": "Zuótiān shàngwǔ nǐ qù nǎr le?",
          "text": {
            "uz": "Kecha ertalab qayerga bordingiz?",
            "ru": "Куда вы ходили вчера утром?",
            "tj": "Дирӯз субҳ шумо куҷо рафтед?"
          }
        },
        {
          "speaker": "B",
          "zh": "我去商店买东西了。",
          "pinyin": "Wǒ qù shāngdiàn mǎi dōngxi le.",
          "text": {
            "uz": "Men do'konga narsa sotib olishga bordim.",
            "ru": "Я ходил в магазин за покупками.",
            "tj": "Ман ба дӯкон рафтам, чизҳо харидам."
          }
        },
        {
          "speaker": "A",
          "zh": "你买什么了？",
          "pinyin": "Nǐ mǎi shénme le?",
          "text": {
            "uz": "Nima sotib oldingiz?",
            "ru": "Что вы купили?",
            "tj": "Шумо чӣ харидед?"
          }
        },
        {
          "speaker": "B",
          "zh": "我买了一点儿苹果。",
          "pinyin": "Wǒ mǎile yīdiǎnr píngguǒ.",
          "text": {
            "uz": "Men bir oz olma sotib oldim.",
            "ru": "Я купил немного яблок.",
            "tj": "Ман каме себ харидам."
          }
        }
      ]
    },
    {
      "scene": {
        "uz": "Kompaniyada — Zhang janobni ko'rdingizmi",
        "ru": "В компании — видели ли вы господина Чжана",
        "tj": "Дар ширкат — ҷаноби Чжанро дидед"
      },
      "dialogue": [
        {
          "speaker": "A",
          "zh": "你看见张先生了吗？",
          "pinyin": "Nǐ kànjiàn Zhāng xiānsheng le ma?",
          "text": {
            "uz": "Janob Jangni ko'rdingizmi?",
