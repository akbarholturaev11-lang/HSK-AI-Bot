      },
      "examples": [
        {
          "zh": "九月去北京旅游最好。",
          "pinyin": "Jiǔ yuè qù Běijīng lǚyóu zuì hǎo.",
          "translation": {
            "uz": "Pekinga sent'abrda borish eng yaxshi.",
