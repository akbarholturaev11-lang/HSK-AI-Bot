          "zh": "都准备好了。",
          "pinyin": "Dōu zhǔnbèi hǎo le.",
          "text": {
            "uz": "Hammasi tayyor.",
            "ru": "Всё готово.",
            "tj": "Ҳама омода."
          }
        }
      ]
    },
