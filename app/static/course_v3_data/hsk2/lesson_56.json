        },
        {
          "zh": "你比我早起一个小时。",
          "pinyin": "Nǐ bǐ wǒ zǎo qǐ yí ge xiǎoshí.",
          "translation": {
            "uz": "Siz mendan bir soat oldin turasiz.",
            "ru": "Ты встаёшь на час раньше меня.",
            "tj": "Шумо аз ман як соат зудтар бармехезед."
          }
        }
      ]
    }
  ],
