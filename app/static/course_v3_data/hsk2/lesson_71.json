  "dialogues": [
    {
      "scene": {
        "uz": "Do'st uyida",
        "ru": "В доме друга",
        "tj": "Дар хонаи дӯст"
      },
      "dialogue": [
        {
          "speaker": "A",
          "zh": "今天是12月20日，新年就要到了。",
          "pinyin": "Jīntiān shì shí'èr yuè èrshí rì, xīnnián jiù yào dào le.",
          "text": {
            "uz": "Bugun 20-dekabr, yangi yil yaqinlashib qoldi.",
            "ru": "Сегодня 20 декабря, новый год уже совсем скоро.",
            "tj": "Имрӯз 20 декабр аст, соли нав наздик шуд."
          }
        },
        {
          "speaker": "B",
          "zh": "新年你准备做什么？",
          "pinyin": "Xīnnián nǐ zhǔnbèi zuò shénme?",
          "text": {
            "uz": "Yangi yilda nima qilishni rejalashtirganmisiz?",
            "ru": "Что ты планируешь делать на новый год?",
            "tj": "Дар соли нав чӣ кор карданӣ ҳастед?"
          }
        },
        {
          "speaker": "A",
          "zh": "我想去北京旅游，北京很不错，我去过一次。",
          "pinyin": "Wǒ xiǎng qù Běijīng lǚyóu, Běijīng hěn búcuò, wǒ qùguo yí cì.",
          "text": {
            "uz": "Pekinga sayohat qilmoqchiman, Pekin juda yaxshi joy, bir marta borgan edim.",
            "ru": "Хочу съездить в Пекин, там очень хорошо, я уже был(а) там один раз.",
            "tj": "Мехоҳам ба Пекин сафар кунам, Пекин хеле хуб аст, як маротиба рафтаам."
          }
        },
        {
          "speaker": "B",
          "zh": "你买票了吗？",
          "pinyin": "Nǐ mǎi piào le ma?",
          "text": {
            "uz": "Chipta oldingizmi?",
            "ru": "Ты уже купил(а) билет?",
            "tj": "Оё шумо чиптаи сафар харидаед?"
          }
        },
        {
          "speaker": "A",
          "zh": "还没有呢，明天就去火车站买票。",
          "pinyin": "Hái méiyǒu ne, míngtiān jiù qù huǒchēzhàn mǎi piào.",
          "text": {
            "uz": "Hali olmadim, ertaga vokzalga borib chipta olaman.",
            "ru": "Ещё нет, завтра пойду на вокзал за билетом.",
            "tj": "Ҳанӯз не, фардо ба вокзал мераваму чипта мехарам."
          }
        }
      ]
    },
    {
      "scene": {
        "uz": "Kompaniyada",
        "ru": "В компании",
        "tj": "Дар ширкат"
      },
      "dialogue": [
        {
          "speaker": "A",
          "zh": "时间过得真快，新的一年快要到了！",
          "pinyin": "Shíjiān guò de zhēn kuài, xīn de yì nián kuài yào dào le!",
          "text": {
            "uz": "Vaqt juda tez o'tar ekan, yangi yil ham tez orada keladi!",
            "ru": "Время летит так быстро, новый год уже вот-вот!",
            "tj": "Вақт хеле зуд мегузарад, соли нав ҳам наздик шуд!"
          }
        },
        {
          "speaker": "B",
          "zh": "是啊，谢谢大家这一年对我的帮助！",
          "pinyin": "Shì a, xièxie dàjiā zhè yì nián duì wǒ de bāngzhù!",
          "text": {
            "uz": "Ha, hammaga bu yil menga bergan yordamlari uchun katta rahmat!",
            "ru": "Да, спасибо всем за помощь в этом году!",
            "tj": "Бале, ташаккур ба ҳама барои ёрии ин сол!"
          }
        },
        {
          "speaker": "C",
          "zh": "希望我们的公司明年更好！",
          "pinyin": "Xīwàng wǒmen de gōngsī míngnián gèng hǎo!",
          "text": {
            "uz": "Umid qilamanki kompaniyamiz kelasi yil yanada yaxshilansin!",
            "ru": "Надеюсь, в следующем году наша компания будет ещё лучше!",
            "tj": "Умедворам ширкати мо соли оянда боз ҳам беҳтар шавад!"
          }
        }
      ]
    },
    {
      "scene": {
        "uz": "Stantsiyada",
        "ru": "На станции",
        "tj": "Дар истгоҳ"
      },
      "dialogue": [
        {
          "speaker": "A",
          "zh": "你妹妹怎么还没来？都八点四十了！",
          "pinyin": "Nǐ mèimei zěnme hái méi lái? Dōu bā diǎn sìshí le!",
          "text": {
            "uz": "Singling nima uchun hali kelmadi? Soat sakkiz qirq bo'lib qoldi!",
            "ru": "Почему твоя сестра ещё не пришла? Уже восемь сорок!",
            "tj": "Чаро хоҳари хурдиат ҳанӯз наомад? Дигар соати ҳашту чил шуд!"
          }
        },
        {
          "speaker": "B",
          "zh": "我们再等她几分钟吧。",
          "pinyin": "Wǒmen zài děng tā jǐ fēnzhōng ba.",
          "text": {
            "uz": "Uni yana bir necha daqiqa kutaylik.",
            "ru": "Давай подождём её ещё несколько минут.",
            "tj": "Биёед чанд дақиқаи дигар интизораш шавем."
          }
        },
        {
          "speaker": "A",
          "zh": "都等她半个小时了！",
          "pinyin": "Dōu děng tā bàn ge xiǎoshí le!",
          "text": {
            "uz": "Uni yarim soatdan beri kutib turibmiz!",
            "ru": "Мы уже полчаса её ждём!",
            "tj": "Мо нимсоат интизораш шудем!"
          }
        },
        {
          "speaker": "B",
          "zh": "她来了，我听见她说话了。",
          "pinyin": "Tā lái le, wǒ tīngjiàn tā shuōhuà le.",
          "text": {
            "uz": "U keldi, uning gapirayotganini eshitdim.",
            "ru": "Она пришла, я слышу, как она говорит.",
            "tj": "Вай омад, ман садои ӯро шунидам."
          }
        }
      ]
    },
    {
      "scene": {
        "uz": "Qahvaxona oldida",
        "ru": "У входа в кафе",
        "tj": "Дар пеши қаҳвахона"
      },
      "dialogue": [
        {
          "speaker": "A",
          "zh": "天阴了，我要回去了。",
          "pinyin": "Tiān yīn le, wǒ yào huíqù le.",
          "text": {
            "uz": "Osmon bulutlandi, ketishim kerak.",
            "ru": "Небо затянулось тучами, мне нужно идти.",
            "tj": "Осмон абрнок шуд, бояд бираваm."
          }
        },
        {
          "speaker": "B",
          "zh": "好的，快要下雨了，你路上慢点儿。",
          "pinyin": "Hǎo de, kuài yào xiàyǔ le, nǐ lùshang màn diǎnr.",
          "text": {
            "uz": "Yaxshi, tez orada yomg'ir yog'adi, yo'lda ehtiyot bo'ling.",
            "ru": "Хорошо, скоро пойдёт дождь, будьте осторожны в дороге.",
            "tj": "Хуб, зуд борон мешавад, дар роҳ эҳтиёт шавед."
          }
        },
        {
          "speaker": "A",
          "zh": "没关系，我坐公共汽车。",
          "pinyin": "Méi guānxi, wǒ zuò gōnggòng qìchē.",
          "text": {
            "uz": "Muammo yo'q, men avtobus bilan boraman.",
            "ru": "Ничего, я поеду на автобусе.",
            "tj": "Мушкил нест, ман бо автобус мераваm."
          }
        },
        {
          "speaker": "B",
          "zh": "好的，再见。",
          "pinyin": "Hǎo de, zàijiàn.",
          "text": {
            "uz": "Yaxshi, xayr.",
            "ru": "Хорошо, до свидания.",
            "tj": "Хуб, хайр."
          }
        }
      ]
    }
  ],
