      "dialogue": [
        {
          "speaker": "A",
          "zh": "吃药了吗？现在身体怎么样？",
          "pinyin": "Chī yào le ma? Xiànzài shēntǐ zěnmeyàng?",
          "text": {
            "uz": "Dori ichdingmi? Hozir sog'liqing qanday?",
            "ru": "Ты принял лекарство? Как сейчас самочувствие?",
            "tj": "Оё дору хӯрдӣ? Ҳоло саломатиат чӣ тавр аст?"
          }
        },
        {
          "speaker": "B",
          "zh": "吃了。现在好多了。",
          "pinyin": "Chī le. Xiànzài hǎo duō le.",
          "text": {
            "uz": "Ichdim. Hozir ancha yaxshi.",
            "ru": "Принял. Сейчас намного лучше.",
            "tj": "Хӯрдам. Ҳоло хеле беҳтар шудам."
          }
        },
        {
          "speaker": "A",
          "zh": "什么时候能出院？",
          "pinyin": "Shénme shíhou néng chūyuàn?",
          "text": {
            "uz": "Qachon kasalxonadan chiqasiz?",
            "ru": "Когда вы сможете выписаться?",
            "tj": "Кай аз беморхона баромада метавонед?"
          }
        },
        {
          "speaker": "B",
          "zh": "医生说下个星期。",
          "pinyin": "Yīshēng shuō xià ge xīngqī.",
          "text": {
            "uz": "Shifokor keyingi haftada, dedi.",
            "ru": "Врач сказал — на следующей неделе.",
            "tj": "Духтур гуфт ҳафтаи оянда."
          }
        }
      ]
    },
    {
      "scene": {
        "uz": "Sport maydonchasida",
        "ru": "На площадке",
        "tj": "Дар майдончаи варзишӣ"
      },
      "dialogue": [
        {
          "speaker": "A",
          "zh": "大卫今年多大？",
          "pinyin": "Dàwèi jīnnián duō dà?",
          "text": {
            "uz": "Devid bu yil necha yoshda?",
            "ru": "Сколько лет Дэвиду в этом году?",
            "tj": "Дэвид имсол чанд сола шудааст?"
          }
        },
        {
          "speaker": "B",
          "zh": "二十多岁。",
          "pinyin": "Èrshí duō suì.",
          "text": {
            "uz": "Yigirma yoshdan oshgan.",
            "ru": "Больше двадцати лет.",
            "tj": "Зиёда аз бист сол."
          }
        },
        {
          "speaker": "A",
          "zh": "他多高？",
          "pinyin": "Tā duō gāo?",
          "text": {
            "uz": "Uning bo'yi qancha?",
            "ru": "Какой у него рост?",
            "tj": "Қади ӯ чанд аст?"
          }
        },
        {
          "speaker": "B",
          "zh": "一米八几。",
          "pinyin": "Yì mǐ bā jǐ.",
          "text": {
            "uz": "Bir metr saksoni bir necha santimetr.",
            "ru": "Метр восемьдесят с чем-то.",
            "tj": "Як метру ҳаштоду чанд."
          }
        },
        {
          "speaker": "A",
          "zh": "你怎么知道这么多啊？",
          "pinyin": "Nǐ zěnme zhīdào zhème duō a?",
          "text": {
            "uz": "Sen bularni qanday bilasan?",
            "ru": "Откуда ты так много знаешь?",
            "tj": "Чӣ тавр ин қадар медонӣ?"
          }
        },
        {
          "speaker": "B",
          "zh": "他是我同学。",
          "pinyin": "Tā shì wǒ tóngxué.",
          "text": {
            "uz": "U mening sinfдошim.",
            "ru": "Он мой однокурсник.",
            "tj": "Ӯ ҳамсинфи ман аст."
          }
        }
      ]
    },
    {
      "scene": {
        "uz": "Xonada",
        "ru": "В комнате",
        "tj": "Дар хона"
      },
      "dialogue": [
        {
          "speaker": "A",
          "zh": "张老师星期六也不休息啊？",
          "pinyin": "Zhāng lǎoshī xīngqīliù yě bù xiūxi a?",
          "text": {
            "uz": "Zhang o'qituvchi shanba kuni ham dam olmaydi, shundaymi?",
            "ru": "Учитель Чжан и в субботу не отдыхает?",
            "tj": "Муаллим Чжан рӯзи шанбе ҳам истироҳат намекунад?"
          }
        },
        {
          "speaker": "B",
          "zh": "是啊，他这几天很忙，没有时间休息。",
          "pinyin": "Shì a, tā zhè jǐ tiān hěn máng, méiyǒu shíjiān xiūxi.",
          "text": {
            "uz": "Ha, u bu bir necha kunda juda band, dam olishga vaqti yo'q.",
            "ru": "Да, он эти несколько дней очень занят, нет времени отдыхать.",
            "tj": "Бале, ӯ ин чанд рӯз хеле банд аст, вақт барои истироҳат надорад."
          }
        },
        {
          "speaker": "A",
          "zh": "那会很累吧？",
          "pinyin": "Nà huì hěn lèi ba?",
          "text": {
            "uz": "U holda juda charchagan bo'lsa kerak?",
            "ru": "Наверное, он очень устаёт?",
            "tj": "Пас ӯ хеле хаста мешавад?"
          }
        },
        {
          "speaker": "B",
          "zh": "他每天回来都很累。",
          "pinyin": "Tā měitiān huílái dōu hěn lèi.",
          "text": {
            "uz": "U har kuni qaytib kelganida juda charchagan bo'ladi.",
            "ru": "Он каждый день возвращается очень усталым.",
            "tj": "Ӯ ҳар рӯз хеле хаста бармегардад."
          }
        }
      ]
    }
