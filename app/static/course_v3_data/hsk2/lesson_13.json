  "grammar": [
    {
      "no": 1,
      "title": {
        "uz": "'Zhe' harakat yuklamasi",
        "ru": "Динамическая частица '着'",
        "tj": "Зарраи динамикии '着'"
      },
      "title_zh": "动态助词“着”",
      "rule": {
        "uz": "'Zhe' yuklamasi fe'ldan keyin kelib, holatning davom etayotganligini bildiradi (statik holat). Bu ingliz tilidagi '-ing' bilan hosil qilingan sifatdoshga o'xshaydi, lekin harakat emas, balki holat davomiyligini ifodalaydi. Masalan: 门开着 (eshik ochiq turibdi), 手里拿着铅笔 (qo'lida qalam ushlab turibdi). Inkor: 没 + fe'l + 着.",
        "ru": "Частица '着' ставится после глагола и обозначает продолжение состояния (статическое состояние). Похоже на причастие с '-ing' в английском, но выражает не действие, а его длительность. Например: 门开着 (дверь открыта), 手里拿着铅笔 (держит в руке карандаш). Отрицание: 没 + глагол + 着.",
        "tj": "Зарраи '着' баъд аз феъл меояд ва давомнокии ҳолатро нишон медиҳад (ҳолати статикӣ). Ба феъли иштиракии '-ing' дар забони англисӣ монанд аст, аммо на амал балки давомнокии ҳолатро ифода мекунад. Масалан: 门开着 (дар кушода истодааст), 手里拿着铅笔 (дар дасташ қалам дорад). Инкор: 没 + феъл + 着."
      },
      "examples": [
        {
          "zh": "门开着呢，请进。",
          "pinyin": "Mén kāi zhe ne, qǐng jìn.",
          "translation": {
            "uz": "Eshik ochiq turibdi, kiring.",
            "ru": "Дверь открыта, заходите.",
            "tj": "Дар кушода истодааст, дарояд."
          }
        },
        {
          "zh": "他手里拿着一本书。",
          "pinyin": "Tā shǒu lǐ ná zhe yì běn shū.",
          "translation": {
            "uz": "U qo'lida bir kitob ushlab turibdi.",
            "ru": "Он держит в руке одну книгу.",
            "tj": "Ӯ дар дасташ як китоб дорад."
          }
        }
      ]
    },
    {
      "no": 2,
      "title": {
        "uz": "Ritorik savol '不是……吗'",
        "ru": "Риторический вопрос '不是……吗'",
        "tj": "Пурсиши риторикии '不是……吗'"
      },
      "title_zh": "反问句“不是……吗”",
      "rule": {
        "uz": "'Bú shì……ma' konstruktsiyasi ritorik savol hosil qiladi: siz allaqachon bilib turib, tasdiqlash uchun savol qo'yasiz. O'zbek tilidagi '…-ku?' yoki '…emasmi?' ma'nosini beradi. Bu ma'lumotni eslatish yoki hayrat bildirish uchun ishlatiladi.",
        "ru": "Конструкция '不是……吗' образует риторический вопрос: вы уже знаете ответ и задаёте вопрос для подтверждения. Аналог русского '…же?' или '…разве нет?'. Используется для напоминания информации или выражения удивления.",
        "tj": "Конструксияи '不是……吗' пурсиши риторикӣ месозад: шумо аллакай медонед ва барои тасдиқ мепурсед. Ба '…-ку?' ё '…нест?' дар забони тоҷикӣ монанд аст. Барои ёдоварии маълумот ё ифодаи ҳайрат истифода мешавад."
      },
      "examples": [
        {
          "zh": "她不是有男朋友了吗？",
          "pinyin": "Tā bú shì yǒu nánpéngyou le ma?",
          "translation": {
