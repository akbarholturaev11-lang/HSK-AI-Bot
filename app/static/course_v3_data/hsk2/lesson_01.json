          }
        },
        {
          "zh": "我最喜欢踢足球。",
          "pinyin": "Wǒ zuì xǐhuan tī zúqiú.",
          "translation": {
            "uz": "Men eng ko'p futbol o'ynashni yaxshi ko'raman.",
            "ru": "Больше всего я люблю играть в футбол.",
            "tj": "Ман аз ҳама бештар футбол бозӣ кардан ро дӯст медорам."
          }
        }
      ]
