BOT_TOKEN=
OPENAI_API_KEY=

# Gemini asosiy AI provayder. To'ldirilsa Gemini ishlaydi, bo'sh bo'lsa yoki
# xato bersa OpenAI zaxira sifatida ishga tushadi.
GEMINI_API_KEY=
# Admin panelda model tanlanmagan bo'lsa ishlatiladigan standart Gemini modeli.
GEMINI_MODEL=gemini-2.5-flash
# Gemini'ning OpenAI-mos endpointi (odatda o'zgartirilmaydi).
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/telegram_chinese_bot
REDIS_URL=redis://localhost:6379/0

ADMIN_IDS=7965751363
FEEDBACK_NOTIFY_CHAT_IDS=-1004311413349
BOT_USERNAME=
MINI_APP_BASE_URL=https://telegram-chinese-bot-production.up.railway.app/course-v3.html
# Optional persistent upload root. On Railway, attach a Volume and set this to the mount path
# or rely on RAILWAY_VOLUME_MOUNT_PATH. Without persistent storage, uploaded course ads
# disappear after deploy/restart.
MEDIA_ROOT=

DEFAULT_LANGUAGE=tj
LOG_LEVEL=INFO
